/*
 * AI Skill: ReadWebpage
 *
 * describe convention:
 *   input "describe" -> return JSON skill declaration
 *   otherwise        -> normal execution
 */

#define name ReadWebpage
#define glyph globe
#define color blue

#include 'actions/web'

@input = "{ShortcutInput}"

if input == "describe" {
    @desc = '{"name":"ReadWebpage","desc":"搜索或读取网页。传入关键词会自动搜索，传入URL会直接读取。拿到搜索结果后，可以从中选择具体URL再次调用获取详细内容，可反复调用直到信息充足。","input":"关键词或URL","output":"网页正文文本"}'
    output("{desc}")
} else {
    @url = "{input}"
    @hasScheme = false
    if input beginsWith "http" {
        @hasScheme = true
    }
    if hasScheme == false {
        @encoded = urlEncode(input)
        @url = "https://cn.bing.com/search?q={encoded}"
    }
    const page = getArticle(url)
    @body = getArticleDetail(page, "Body")
    output("Source: {url}\n\n{body}")
}
